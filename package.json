{
  "name": "attendance-app-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web:prod": "expo export --platform web",
    "serve:web:prod": "serve -s dist -l 4173",
    "start:local": "mkdir -p .home && HOME=$PWD/.home PATH=$PWD/.local/node-v20.20.1-darwin-arm64/bin:$PATH expo start",
    "android:local": "mkdir -p .home && HOME=$PWD/.home PATH=$PWD/.local/node-v20.20.1-darwin-arm64/bin:$PATH expo start --android",
    "ios:local": "mkdir -p .home && HOME=$PWD/.home PATH=$PWD/.local/node-v20.20.1-darwin-arm64/bin:$PATH expo start --ios",
    "web:local": "mkdir -p .home && HOME=$PWD/.home PATH=$PWD/.local/node-v20.20.1-darwin-arm64/bin:$PATH expo start --web"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "axios": "^1.8.4",
    "expo": "^54.0.0",
    "expo-location": "~19.0.8",
    "expo-status-bar": "~3.0.9",
    "leaflet": "^1.9.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-leaflet": "^5.0.0",
    "react-native": "0.81.5",
    "react-native-maps": "1.20.1",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "babel-preset-expo": "~54.0.10",
    "eas-cli": "^18.4.0",
    "serve": "^14.2.4"
  }
}
